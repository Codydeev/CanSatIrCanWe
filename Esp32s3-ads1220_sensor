#include <SPI.h>
#include <ADS1220_WE.h>

#define ADS1220_CS_PIN 7
#define ADS1220_DRDY_PIN 6

ADS1220_WE ads = ADS1220_WE(&SPI, ADS1220_CS_PIN, ADS1220_DRDY_PIN,10, 9, 8);
// ADS1220_WE ads = ADS1220_WE(&SPI, ADS1220_CS_PIN, ADS1220_DRDY_PIN, YOUR_MOSI, YOUR_MISO, YOUR_SCLK);
void setup() {
  // put your setup code here, to run once:
  SPI.begin(8, 9, 10,7);
  SPISETTINGS settings(1000000, MSBFIRST, SPI_MODE1);
  Serial.begin(115200);
  Serial.print("hej1");
  ads.bypassPGA(true);
  Serial.print("ADS1220 setup färdig");
  delay(10000);
}  

void loop() {
  // put your main code here, to run repeatedly:
  float result = 0.0;
  long longresult = 0;

  ads.setCompareChannels(ADS1220_MUX_0_1);
  result = ads.getVoltage_mV();
  longresult = ads.getRawData();
  Serial.print("AIN0 vs. AIN1   ");
  Serial.println(result);
  Serial.print("AIN0 vs. AIN1   ");
  Serial.println(longresult);

  delay(20);
}
